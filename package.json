{
  "name": "reelme",
  "version": "0.1.1",
  "description": "Generate animated explainer videos for any open-source project",
  "bin": {
    "reelme": "./dist/index.js"
  },
  "files": [
    "dist/",
    "template/"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build",
    "release:patch": "pnpm version patch && git push --follow-tags",
    "release:minor": "pnpm version minor && git push --follow-tags",
    "release:major": "pnpm version major && git push --follow-tags"
  },
  "dependencies": {
    "commander": "latest",
    "fs-extra": "latest",
    "picocolors": "latest"
  },
  "devDependencies": {
    "@types/fs-extra": "latest",
    "@types/node": "latest",
    "typescript": "latest"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
