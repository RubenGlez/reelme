{
  "schemaVersion": 2,
  "project": {
    "name": "Pake",
    "tagline": "Any website, a tiny desktop app.",
    "problem": "Electron apps ship hundreds of megabytes for a single web page.",
    "installCommand": "pnpm install -g pake-cli",
    "repoUrl": "github.com/tw93/Pake",
    "primaryColor": "#14b8a6",
    "tone": "playful",
    "look": "editorial",
    "mode": "intro",
    "bgStyle": "branded",
    "platforms": ["github-readme", "tiktok", "instagram-reel"],
    "audio": { "track": "sunny-loop.mp3" },
    "watermark": true
  },
  "cuts": {
    "main": [
      { "type": "hook", "kicker": "Pake", "align": "left", "text": "Turn any website into a desktop app.", "accent": "desktop app." },
      { "type": "split", "before": { "label": "Electron", "content": "~150 MB for a single web page" }, "after": { "label": "Pake", "content": "~5 MB native app, built on Rust" }, "caption": "Same web app. A fraction of the size." },
      { "type": "feature-list", "align": "left", "headline": "One command, a real app", "items": [ { "text": "Built on Tauri and Rust", "icon": "package" }, { "text": "Global shortcuts and themes", "icon": "settings" }, { "text": "macOS, Windows, and Linux", "icon": "hard-drive" } ] },
      { "type": "cta", "installCommand": "pnpm install -g pake-cli", "repoUrl": "github.com/tw93/Pake", "caption": "Your favorite site, as an app." }
    ],
    "vertical": [
      { "type": "hook", "kicker": "Pake", "text": "Any website, a tiny desktop app.", "accent": "tiny desktop app." },
      { "type": "split", "before": { "label": "Electron", "content": "~150 MB" }, "after": { "label": "Pake", "content": "~5 MB" }, "caption": "A fraction of the size." },
      { "type": "cta", "installCommand": "pnpm install -g pake-cli", "repoUrl": "github.com/tw93/Pake" }
    ],
    "teaser": [
      { "type": "hook", "text": "Any website, a 5 MB desktop app.", "accent": "5 MB" },
      { "type": "cta", "installCommand": "pnpm install -g pake-cli", "repoUrl": "github.com/tw93/Pake" }
    ]
  }
