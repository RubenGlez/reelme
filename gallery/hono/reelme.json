{
  "schemaVersion": 2,
  "project": {
    "name": "Hono",
    "tagline": "Small, simple, ultrafast — on every runtime.",
    "problem": "Most web frameworks lock you to a single runtime.",
    "installCommand": "npm create hono@latest",
    "repoUrl": "github.com/honojs/hono",
    "primaryColor": "#e36209",
    "secondaryColor": "#fbbf24",
    "tone": "professional",
    "look": "keynote",
    "mode": "intro",
    "bgStyle": "deep",
    "platforms": [
      "github-readme",
      "x",
      "linkedin"
    ],
    "audio": {
      "track": "calm-keys.mp3"
    },
    "watermark": true,
    "logo": "logo.png"
  },
  "cuts": {
    "main": [
      {
        "type": "code-reveal",
        "language": "typescript",
        "code": "import { Hono } from 'hono'\n\nconst app = new Hono()\n\napp.get('/', (c) => c.text('Hello Hono!'))\n\nexport default app",
        "highlightLine": 5,
        "caption": "The same app runs on Bun, Deno, Node, and the edge."
      },
      {
        "type": "browser",
        "url": "hono.dev",
        "caption": "Fast, lightweight, built on Web Standards.",
        "image": "site-hero.png"
      },
      {
        "type": "stat-callout",
        "layout": "hero",
        "headline": "One of the fastest",
        "stats": [
          {
            "value": "402k",
            "label": "requests/sec on Bun — from a framework that's only a few KB."
          },
          {
            "value": "0",
            "label": "runtime lock-in"
          }
        ],
        "caption": "Tiny, typed, and dependency-free."
      },
      {
        "type": "feature-list",
        "align": "left",
        "headline": "Runs everywhere",
        "items": [
          {
            "text": "Cloudflare Workers, Deno, Bun, Node, Lambda",
            "icon": "globe"
          },
          {
            "text": "A few KB, zero dependencies",
            "icon": "zap"
          },
          {
            "text": "Typed routing and middleware",
            "icon": "check"
          }
        ]
      },
      {
        "type": "cta",
        "installCommand": "npm create hono@latest",
        "repoUrl": "github.com/honojs/hono",
        "caption": "Build once, run anywhere."
      }
    ]
  }
}
