{
  "project": {
    "name": "reelme",
    "tagline": "Your README, but as a video.",
    "problem": "OSS projects go unnoticed because text READMEs don't grab attention.",
    "installCommand": "npx skills add RubenGlez/reelme",
    "repoUrl": "github.com/RubenGlez/reelme",
    "primaryColor": "#6366f1",
    "tone": "professional",
    "logo": "logo.svg"
  },
  "scenes": [
    {
      "type": "problem",
      "headline": "Your README doesn't grab attention.",
      "subtext": "Most people skim past walls of text.",
      "caption": "Developers judge a project in seconds."
    },
    {
      "type": "feature-list",
      "headline": "Everything you need. Nothing you don't.",
      "items": [
        "Reads your repo automatically",
        "Renders MP4 and GIF locally",
        "Works with any agent"
      ],
      "caption": "Zero config. Full output."
    },
    {
      "type": "data-flow",
      "nodes": [
        { "id": "repo", "label": "Your repo" },
        { "id": "claude", "label": "Claude" },
        { "id": "brief", "label": "brief.json" },
        { "id": "remotion", "label": "Remotion" },
        { "id": "video", "label": "video.mp4" }
      ],
      "edges": [
        { "from": "repo", "to": "claude", "label": "reads" },
        { "from": "claude", "to": "brief", "label": "writes" },
        { "from": "brief", "to": "remotion", "label": "drives" },
        { "from": "remotion", "to": "video", "label": "renders" }
      ],
      "caption": "Claude writes the brief. Remotion does the rest."
    },
    {
      "type": "cta",
      "installCommand": "npx skills add RubenGlez/reelme",
      "repoUrl": "github.com/RubenGlez/reelme",
      "caption": "Star it, share it, ship it."
    }
  ]
}
