{
  "project": {
    "name": "reelme",
    "tagline": "Your README, but as a video.",
    "problem": "OSS projects go unnoticed because text READMEs don't grab attention.",
    "installCommand": "npx reelme",
    "repoUrl": "github.com/you/reelme",
    "primaryColor": "#6366f1",
    "tone": "professional",
    "logo": "logo.png"
  },
  "scenes": [
    {
      "type": "problem",
      "headline": "Your README doesn't grab attention.",
      "subtext": "Most people skim past walls of text.",
      "caption": "Developers judge a project in seconds."
    },
    {
      "type": "feature-list",
      "headline": "Everything you need. Nothing you don't.",
      "items": [
        "Reads your repo automatically",
        "Asks only what it can't infer",
        "Renders MP4 and GIF locally",
        "Works with any language or framework"
      ],
      "caption": "Zero config. Full output."
    },
    {
      "type": "split",
      "before": {
        "label": "Without reelme",
        "content": "# My Project\n\nA tool that does stuff.\n\n## Installation\n\nnpm install my-project\n\n## Usage\n\n..."
      },
      "after": {
        "label": "With reelme",
        "content": "▶  30-second animated video\n   showing exactly what it does,\n   how to install it, and why\n   it's worth your time."
      },
      "caption": "Show, don't tell."
    },
    {
      "type": "code-reveal",
      "language": "ts",
      "code": "// Run /reelme in any Claude Code session\n// Claude reads your repo and asks a few questions\n// Then generates an animated explainer video\n\nconst video = await reelme({\n  repo: '.',\n  primaryColor: '#6366f1',\n});\n\nconsole.log(video.mp4); // video/out/video.mp4",
      "highlightLine": 5,
      "caption": "One command. One video."
    },
    {
      "type": "terminal",
      "commands": [
        { "input": "npx reelme", "output": "Reading repo..." },
        { "input": "", "output": "✔ Inferred: name, tagline, install command" },
        { "input": "", "output": "? Primary color: #6366f1" },
        { "input": "", "output": "Rendering video/out/video.mp4 ..." },
        { "input": "", "output": "✔ Done in 18s" }
      ],
      "caption": "Works in any repo, no config needed."
    },
    {
      "type": "data-flow",
      "nodes": [
        { "id": "repo", "label": "Your repo" },
        { "id": "claude", "label": "Claude" },
        { "id": "brief", "label": "brief.json" },
        { "id": "remotion", "label": "Remotion" },
        { "id": "video", "label": "video.mp4" }
      ],
      "edges": [
        { "from": "repo", "to": "claude", "label": "reads" },
        { "from": "claude", "to": "brief", "label": "writes" },
        { "from": "brief", "to": "remotion", "label": "drives" },
        { "from": "remotion", "to": "video", "label": "renders" }
      ],
      "caption": "Claude handles the brief. Remotion handles the rendering."
    },
    {
      "type": "stat-callout",
      "headline": "Built for speed.",
      "stats": [
        { "value": "10x", "label": "Faster than manual editing" },
        { "value": "30s", "label": "Average render time" },
        { "value": "0", "label": "Config files needed" }
      ],
      "caption": "Numbers that speak for themselves."
    },
    {
      "type": "file-tree",
      "headline": "Clean output.",
      "entries": [
        { "path": "video/", "type": "dir" },
        { "path": "video/src/", "type": "dir" },
        { "path": "video/src/brief.json", "type": "file", "highlight": true },
        { "path": "video/src/Root.tsx", "type": "file" },
        { "path": "video/out/", "type": "dir" },
        { "path": "video/out/video.mp4", "type": "file", "highlight": true },
        { "path": "video/out/video.gif", "type": "file", "highlight": true }
      ],
      "caption": "Edit brief.json, re-run, done."
    },
    {
      "type": "mobile",
      "title": "reelme",
      "caption": "Looks great everywhere."
    },
    {
      "type": "browser",
      "url": "github.com/you/reelme",
      "caption": "Ships as a shareable MP4 or GIF."
    },
    {
      "type": "cta",
      "installCommand": "npx reelme",
      "repoUrl": "github.com/you/reelme",
      "caption": "Star it, share it, ship it."
    }
  ]
}
